# =========================================
# APP
# =========================================
APP_ENV=local

# =========================================
# SERVER
# =========================================
BACKEND_PORT=8081
FRONTEND_PORT=3000

# =========================================
# DATABASE
# =========================================
DATABASE_URL=postgres://postgres:postgres@localhost:55432/marketplace_ai?sslmode=disable
MIGRATIONS_PATH=./migrations

# =========================================
# REDIS
# =========================================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# =========================================
# S3 / MINIO
# =========================================
S3_ENDPOINT=localhost:19000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET_RAW=raw-payloads
S3_BUCKET_EXPORTS=exports
S3_BUCKET_ARTIFACTS=artifacts
S3_USE_SSL=false

# =========================================
# AUTH SECRETS
# =========================================
JWT_SECRET=replace-me
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# =========================================
# SENTRY
# =========================================
SENTRY_DSN=
SENTRY_RELEASE=dev

# =========================================
# TELEMETRY
# =========================================
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=marketplace-ai-backend

# =========================================
# OPENAI
# =========================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2

# =========================================
# STAGE 13 — AI HARDENING (MVP, not billing limits)
# =========================================
# Caps recommendation context before OpenAI (items per list + JSON byte budget).
AI_RECOMMENDATION_MAX_CONTEXT_ITEMS=50
AI_RECOMMENDATION_MAX_CONTEXT_BYTES=491520
# Chat fact context assembler limits.
AI_CHAT_MAX_CONTEXT_ITEMS=20
AI_CHAT_MAX_CONTEXT_BYTES=51200
# Rough pre-flight limit on request JSON size (len/4 heuristic); 0 would disable in code paths that read env.
AI_MAX_INPUT_TOKENS_APPROX=120000
AI_MAX_OUTPUT_TOKENS=4096

# Optional worker maintenance: archive stale active chat sessions (no DELETE of business data).
CLEANUP_ENABLED=false
CLEANUP_RETENTION_DAYS=90
# Go duration string, e.g. 168h = weekly enqueue from worker.
CLEANUP_SCHEDULE=168h

# =========================================
# FRONTEND PUBLIC CONFIG
# =========================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_RELEASE=dev

AUTH_COOKIE_NAME=session_token
AUTH_SESSION_TTL_HOURS=168

# Admin/support access allowlist for /api/v1/admin/* endpoints.
# Comma-separated emails. Leave empty to disable admin access.
ADMIN_EMAILS=