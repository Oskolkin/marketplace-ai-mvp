# =========================================
# APP
# =========================================
APP_ENV=local

# =========================================
# SERVER
# =========================================
BACKEND_PORT=8081
FRONTEND_PORT=3000

# =========================================
# DATABASE
# =========================================
DATABASE_URL=postgres://postgres:postgres@localhost:55432/marketplace_ai?sslmode=disable
MIGRATIONS_PATH=./migrations

# =========================================
# REDIS
# =========================================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# =========================================
# S3 / MINIO
# =========================================
S3_ENDPOINT=localhost:19000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET_RAW=raw-payloads
S3_BUCKET_EXPORTS=exports
S3_BUCKET_ARTIFACTS=artifacts
S3_USE_SSL=false

# =========================================
# AUTH SECRETS
# =========================================
JWT_SECRET=replace-me
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# =========================================
# SENTRY
# =========================================
SENTRY_DSN=
SENTRY_RELEASE=dev

# =========================================
# TELEMETRY
# =========================================
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=marketplace-ai-backend

# =========================================
# OPENAI
# =========================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2

# =========================================
# FRONTEND PUBLIC CONFIG
# =========================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_RELEASE=dev

AUTH_COOKIE_NAME=session_token
AUTH_SESSION_TTL_HOURS=168